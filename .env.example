# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/onespace-dev-db

# Authentication
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=1h
TOKEN_ENCRYPTION_KEY=replace_with_a_32_plus_character_secret

# Google integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_SYNC_LOOKBACK_DAYS=30
PUBSUB_VERIFICATION_TOKEN=

# Security / CORS
ALLOWED_ORIGINS=http://localhost:4200,https://onespace-ui-latest.onrender.com
FRONTEND_URL=http://localhost:4200
# Expense tracker
EXPENSE_MONTHLY_BUDGET=30000
